        <mxCell id="title" value="OmniGas · 全能服务费  —  无需持有 ETH，轻松上链" style="text;fontSize=22;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="100" y="30" width="970" height="40" as="geometry" />
